# Etherscan API Key(必填,免费获取:https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=YourEtherscanApiKeyHere

# LLM 配置(Anthropic 兼容协议)
# 用 MIMO_* 而不是 ANTHROPIC_*,避免被 Claude Code 等工具的系统级环境变量覆盖
#
# 选项 A:小米 MiMo(国内推荐)
#   MIMO_BASE_URL = 你在小米套餐页面看到的"专属 Base URL"(以 /anthropic 结尾)
#   MIMO_API_KEY  = 你在小米套餐页面看到的"专属 API Key"
#   LLM_MODEL     = mimo-v2.5-pro / mimo-v2-pro / mimo-v2-omni
#
# 选项 B:Anthropic 官方
#   MIMO_API_KEY  = sk-ant-xxx
#   MIMO_BASE_URL = https://api.anthropic.com
#   LLM_MODEL     = claude-haiku-4-5-20251001

MIMO_API_KEY=
MIMO_BASE_URL=
LLM_MODEL=mimo-v2.5-pro
